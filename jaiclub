<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>JAI CLUB</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial, sans-serif;
}

body{
    height:100vh;
    display:flex;
    justify-content:center;
    align-items:center;
    background:linear-gradient(-45deg,#0f172a,#1e293b,#2563eb,#7c3aed);
    background-size:400% 400%;
    animation:bgMove 10s ease infinite;
}

@keyframes bgMove{
    0%{background-position:0% 50%;}
    50%{background-position:100% 50%;}
    100%{background-position:0% 50%;}
}

.container{
    text-align:center;
    padding:40px 25px;
    width:90%;
    max-width:450px;
    background:rgba(255,255,255,0.08);
    backdrop-filter:blur(15px);
    border-radius:25px;
    border:1px solid rgba(255,255,255,0.2);
    box-shadow:0 0 30px rgba(0,0,0,0.3);
}

.logo{
    width:120px;
    height:120px;
    border-radius:50%;
    object-fit:cover;
    border:4px solid #fff;
    animation:float 3s ease-in-out infinite;
}

@keyframes float{
    0%,100%{
        transform:translateY(0);
    }
    50%{
        transform:translateY(-10px);
    }
}

h1{
    color:#fff;
    margin-top:20px;
    font-size:42px;
    font-weight:bold;
    text-shadow:0 0 20px rgba(255,255,255,0.5);
}

.subtitle{
    color:#ddd;
    margin-top:10px;
    margin-bottom:30px;
    font-size:16px;
}

.telegram-btn{
    display:inline-block;
    text-decoration:none;
    color:#fff;
    background:linear-gradient(45deg,#0088cc,#00c6ff);
    padding:18px 40px;
    border-radius:50px;
    font-size:20px;
    font-weight:bold;
    transition:.3s;
    animation:pulse 2s infinite;
    box-shadow:0 0 25px rgba(0,198,255,.6);
}

.telegram-btn:hover{
    transform:scale(1.08);
}

@keyframes pulse{
    0%{
        box-shadow:0 0 0 0 rgba(0,198,255,.7);
    }
    70%{
        box-shadow:0 0 0 25px rgba(0,198,255,0);
    }
    100%{
        box-shadow:0 0 0 0 rgba(0,198,255,0);
    }
}

.footer{
    margin-top:25px;
    color:#bbb;
    font-size:13px;
}
</style>
</head>

<body>

<div class="container">

    <!-- Logo -->
    <img src="photo_2026-06-01_22-47-04.jpg" alt="JAI CLUB Logo" class="logo">

    <!-- Title -->
    <h1>JAI CLUB</h1>

    <p class="subtitle">
        Join Our Official Telegram Channel
    </p>

    <!-- Telegram Button -->
    <a href="https://t.me/+yd9pzclRP2I3OTU9"
       target="_blank"
       class="telegram-btn">
       JOIN TELEGRAM CHANNEL
    </a>

    <div class="footer">
        © 2026 JAI CLUB
    </div>

</div>

</body>
</html>
